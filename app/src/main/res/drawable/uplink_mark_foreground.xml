<?xml version="1.0" encoding="utf-8"?>
<!--
    UPLINK adaptive icon — foreground layer.
    Ported from branding/uplink_mark.svg. Source mark is drawn on a
    512x512 viewBox; adaptive icons use a 108x108dp canvas where only
    the inner 66x66dp is guaranteed visible after launcher masking
    (safe zone = centered 72.9x72.9 in the 108x108 grid, per Android
    adaptive icon spec). The mark is scaled + centered so its full
    frame (including corner brackets) sits inside that safe zone.

    Original mark bounding box (frame + tick): x 96–350, y 96–416
    -> scaled by 0.62 and translated to center within 108x108dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Corner brackets -->
    <path
        android:pathData="M 24,45.6 L 24,32.8 L 36.8,32.8"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 79.4,45.6 L 79.4,32.8 L 66.6,32.8"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 24,73.4 L 24,86.2 L 36.8,86.2"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 79.4,73.4 L 79.4,86.2 L 66.6,86.2"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />

    <!-- Central U -->
    <path
        android:pathData="M 47,49.5 L 47,63.9 Q 47,69.8 53.9,69.8 L 63.1,69.8 Q 70,69.8 70,63.9 L 70,49.5"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="4.7"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />

    <!-- Upward signal tick + dot -->
    <path
        android:pathData="M 70,49.5 L 75.6,40.5"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 75.6,38.6 m -1.9,0 a 1.9,1.9 0 1,0 3.8,0 a 1.9,1.9 0 1,0 -3.8,0"
        android:fillColor="#0DF2C4" />

    <!-- Secondary echo arc -->
    <path
        android:pathData="M 73.3,42.7 Q 75.6,37.4 79.5,40.8"
        android:strokeColor="#0A9C84"
        android:strokeWidth="1.3"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:fillAlpha="0.6"
        android:strokeAlpha="0.6" />

</vector>
