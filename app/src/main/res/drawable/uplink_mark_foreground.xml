<?xml version="1.0" encoding="utf-8"?>
<!--
    UPLINK adaptive icon — foreground layer. REVISED (001.5.2).

    Ported from branding/uplink_mark.svg (512x512 viewBox), scaled by
    0.2108 and offset so the frame lands exactly on the 19–89dp bounds
    of the 108x108dp canvas — inside the ~66x66dp safe zone guaranteed
    visible after launcher masking.

    Change from the original (001.5 / 001.5.1): the tick+dot signal
    indicator read as a location-pin at launcher scale. Replaced with
    two open signal-emission arcs sitting in the frame's upper-right
    pocket. The arcs are NOT mathematically attached to the U's stroke
    endpoint — per design correction, the signal only needs to visually
    belong to the U, not physically touch it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Corner brackets -->
    <path
        android:pathData="M 19,30.17 L 19,19 L 30.17,19"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="2.95"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 89,30.17 L 89,19 L 77.83,19"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="2.95"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 19,77.83 L 19,89 L 30.17,89"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="2.95"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 89,77.83 L 89,89 L 77.83,89"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="2.95"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />

    <!-- Central U -->
    <path
        android:pathData="M 40.3,41.14 L 40.3,63.28 Q 40.3,69.18 46.2,69.18 L 61.8,69.18 Q 67.7,69.18 67.7,63.28 L 67.7,41.14"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="4.64"
        android:strokeLineCap="square"
        android:fillColor="#00000000" />

    <!-- Signal arcs: inner (brighter, closer) and outer (dimmer, offset
         up/right), both in the frame's open upper-right pocket, not
         touching the U or the corner bracket. -->
    <path
        android:pathData="M 61.61,28.07 A 7.38,7.38 0 0,1 72.24,24.21"
        android:strokeColor="#0DF2C4"
        android:strokeWidth="3.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <path
        android:pathData="M 57.65,26.63 A 11.6,11.6 0 0,1 74.35,20.56"
        android:strokeColor="#0A9C84"
        android:strokeWidth="3.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

</vector>
